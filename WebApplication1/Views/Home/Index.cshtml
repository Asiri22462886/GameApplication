@model WebApplication1.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Game Dashboard";
}

<style>
    * {
        box-sizing: border-box;
    }

    :root {
        --bg-dark: #0b1220;
        --bg-mid: #111827;
        --bg-purple: #1e1b4b;
        --card-bg: rgba(255, 255, 255, 0.07);
        --card-border: rgba(255, 255, 255, 0.12);
        --soft-text: #cbd5e1;
        --muted-text: #94a3b8;
        --white: #ffffff;
        --blue: #2563eb;
        --purple: #7c3aed;
    }

    body {
        margin: 0;
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--white);
        background: radial-gradient(circle at 10% 15%, rgba(37,99,235,.22), transparent 20%), radial-gradient(circle at 90% 20%, rgba(124,58,237,.18), transparent 20%), radial-gradient(circle at 80% 90%, rgba(16,185,129,.12), transparent 20%), linear-gradient(135deg, var(--bg-dark) 0%, var(--bg-mid) 45%, var(--bg-purple) 100%);
        overflow-x: hidden;
    }

    .dashboard-page {
        min-height: 100vh;
        padding: 28px 18px 40px;
    }

    .dashboard-shell {
        width: 100%;
        max-width: 1280px;
        margin: 0 auto;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(12, minmax(0, 1fr));
        gap: 22px;
    }

    .card {
        position: relative;
        overflow: hidden;
        border-radius: 26px;
        background: var(--card-bg);
        border: 1px solid var(--card-border);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 20px 60px rgba(0,0,0,.28);
        transition: transform .28s ease, box-shadow .28s ease, border-color .28s ease;
        animation: fadeUp .8s ease both;
    }

        .card:hover {
            transform: translateY(-6px);
            box-shadow: 0 26px 70px rgba(0,0,0,.34);
            border-color: rgba(255,255,255,.20);
        }

    .card-inner {
        padding: 24px;
    }

    .span-3 {
        grid-column: span 3;
    }

    .span-4 {
        grid-column: span 4;
    }

    .span-5 {
        grid-column: span 5;
    }

    .span-6 {
        grid-column: span 6;
    }

    .span-7 {
        grid-column: span 7;
    }

    .span-8 {
        grid-column: span 8;
    }

    .span-12 {
        grid-column: span 12;
    }

    .section-title {
        display: flex;
        align-items: center;
        gap: 10px;
        font-size: 1.08rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

        .section-title .icon {
            width: 38px;
            height: 38px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            border-radius: 12px;
            background: rgba(255,255,255,.08);
            font-size: 1.05rem;
        }

    .section-subtext {
        color: var(--muted-text);
        margin-top: -6px;
        margin-bottom: 18px;
        line-height: 1.6;
    }

    .stats-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 18px;
    }

    .stat-card {
        min-height: 165px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
        padding: 24px;
        border-radius: 24px;
        background: linear-gradient(180deg, rgba(255,255,255,.08), rgba(255,255,255,.05));
        border: 1px solid rgba(255,255,255,.11);
        box-shadow: 0 18px 45px rgba(0,0,0,.18);
        transition: all .25s ease;
        animation: fadeUp .8s ease both;
    }

        .stat-card:hover {
            transform: translateY(-5px);
        }

    .stat-top {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 10px;
    }

    .stat-title {
        color: var(--soft-text);
        font-size: .95rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .stat-icon {
        width: 42px;
        height: 42px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.08);
        font-size: 1.15rem;
    }

    .stat-value {
        font-size: clamp(2rem, 4vw, 2.8rem);
        font-weight: 900;
        line-height: 1;
        margin: 14px 0 8px;
    }

    .stat-note {
        color: var(--muted-text);
        font-size: .94rem;
        line-height: 1.5;
    }

    .hero-card {
        background: linear-gradient(135deg, rgba(37,99,235,.18), rgba(124,58,237,.18)), rgba(255,255,255,.05);
    }

    .hero-content {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 24px;
        min-height: 280px;
    }

    .hero-text {
        max-width: 650px;
    }

    .hero-mini {
        font-size: .82rem;
        color: #dbeafe;
        text-transform: uppercase;
        letter-spacing: .16em;
        font-weight: 800;
        margin-bottom: 14px;
    }

    .hero-title {
        font-size: clamp(2rem, 4vw, 3.6rem);
        line-height: 1.08;
        font-weight: 900;
        margin: 0 0 14px;
    }

    .hero-desc {
        color: #e5e7eb;
        font-size: 1.03rem;
        line-height: 1.8;
        margin-bottom: 22px;
    }

    .hero-actions {
        display: flex;
        gap: 14px;
        flex-wrap: wrap;
    }

    .btn-main,
    .btn-soft {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        text-decoration: none;
        border-radius: 18px;
        padding: 15px 22px;
        font-size: 1rem;
        font-weight: 800;
        transition: all .25s ease;
        border: 1px solid rgba(255,255,255,.12);
    }

    .btn-main {
        background: linear-gradient(90deg, var(--blue), var(--purple));
        color: #fff;
        box-shadow: 0 14px 32px rgba(37,99,235,.28);
    }

        .btn-main:hover {
            color: #fff;
            transform: translateY(-3px);
            box-shadow: 0 20px 38px rgba(124,58,237,.34);
        }

    .btn-soft {
        background: rgba(255,255,255,.07);
        color: #f8fafc;
    }

        .btn-soft:hover {
            color: #fff;
            transform: translateY(-3px);
            background: rgba(255,255,255,.11);
        }

    .hero-visual {
        flex-shrink: 0;
        width: 250px;
        height: 250px;
        border-radius: 28px;
        background: radial-gradient(circle at 30% 30%, rgba(255,255,255,.18), transparent 30%), linear-gradient(135deg, rgba(37,99,235,.30), rgba(124,58,237,.30));
        border: 1px solid rgba(255,255,255,.10);
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: inset 0 0 40px rgba(255,255,255,.03);
    }

    .hero-visual-inner {
        width: 130px;
        height: 130px;
        border-radius: 50%;
        background: rgba(255,255,255,.10);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 3.2rem;
        box-shadow: 0 0 40px rgba(255,255,255,.08);
    }

    .quick-actions {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 16px;
    }

    .quick-card {
        text-decoration: none;
        color: #fff;
        padding: 22px 18px;
        border-radius: 22px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: all .25s ease;
    }

        .quick-card:hover {
            transform: translateY(-5px);
            background: rgba(255,255,255,.08);
            border-color: rgba(255,255,255,.14);
            color: #fff;
        }

    .quick-icon {
        width: 48px;
        height: 48px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.08);
        font-size: 1.2rem;
        margin-bottom: 14px;
    }

    .quick-title {
        font-size: 1.05rem;
        font-weight: 800;
        margin-bottom: 8px;
    }

    .quick-text {
        color: var(--soft-text);
        font-size: .94rem;
        line-height: 1.6;
    }

    .activity-list {
        list-style: none;
        margin: 0;
        padding: 0;
        display: grid;
        gap: 14px;
    }

    .activity-item {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 14px;
        padding: 16px 18px;
        border-radius: 18px;
        background: rgba(255,255,255,.05);
        border: 1px solid rgba(255,255,255,.08);
        transition: all .25s ease;
    }

        .activity-item:hover {
            transform: translateY(-3px);
            background: rgba(255,255,255,.08);
        }

    .activity-left {
        display: flex;
        align-items: center;
        gap: 14px;
    }

    .activity-icon {
        width: 46px;
        height: 46px;
        border-radius: 16px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.08);
        font-size: 1.15rem;
        flex-shrink: 0;
    }

    .activity-details strong {
        display: block;
        margin-bottom: 4px;
        font-size: .98rem;
    }

    .activity-details span {
        color: var(--soft-text);
        font-size: .92rem;
    }

    .score-badge {
        min-width: 88px;
        text-align: center;
        padding: 10px 14px;
        border-radius: 14px;
        background: linear-gradient(135deg, rgba(37,99,235,.22), rgba(124,58,237,.22));
        color: #dbeafe;
        font-weight: 800;
        font-size: .98rem;
    }

    .empty-state {
        text-align: center;
        padding: 36px 20px;
        border-radius: 20px;
        background: rgba(255,255,255,.04);
        border: 1px dashed rgba(255,255,255,.14);
    }

    .empty-emoji {
        font-size: 2.2rem;
        display: block;
        margin-bottom: 10px;
    }

    .empty-state strong {
        display: block;
        margin-bottom: 8px;
        font-size: 1.05rem;
    }

    .empty-state p {
        margin: 0;
        color: var(--soft-text);
    }

    .stagger-1 {
        animation-delay: .05s;
    }

    .stagger-2 {
        animation-delay: .12s;
    }

    .stagger-3 {
        animation-delay: .18s;
    }

    .stagger-4 {
        animation-delay: .24s;
    }

    @@keyframes fadeUp {
        from {
            opacity: 0;
            transform: translateY(22px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@media (max-width: 1199px) {
        .span-3 {
            grid-column: span 6;
        }

        .span-4 {
            grid-column: span 6;
        }

        .span-5 {
            grid-column: span 12;
        }

        .span-7 {
            grid-column: span 12;
        }

        .span-8 {
            grid-column: span 12;
        }

        .hero-content {
            flex-direction: column;
            text-align: center;
        }

        .hero-text {
            max-width: 100%;
        }

        .hero-actions {
            justify-content: center;
        }
    }

    @@media (max-width: 991.98px) {
        .stats-row,
        .quick-actions {
            grid-template-columns: 1fr;
        }

        .span-3,
        .span-4,
        .span-5,
        .span-6,
        .span-7,
        .span-8,
        .span-12 {
            grid-column: span 12;
        }

        .card-inner,
        .stat-card {
            padding: 20px;
        }

        .hero-visual {
            width: 210px;
            height: 210px;
        }
    }

    @@media (max-width: 576px) {
        .dashboard-page {
            padding: 18px 10px 28px;
        }

        .hero-desc {
            font-size: .96rem;
        }

        .activity-item {
            flex-direction: column;
            align-items: flex-start;
        }

        .score-badge {
            width: 100%;
        }

        .hero-actions {
            flex-direction: column;
        }

        .btn-main,
        .btn-soft {
            width: 100%;
        }
    }
</style>

<div class="dashboard-page">
    <div class="dashboard-shell">
        <div class="dashboard-grid">

            <div class="span-12 stagger-1">
                <div class="stats-row">
                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-title">Highest Score</div>
                            <div class="stat-icon">🏆</div>
                        </div>
                        <div class="stat-value">@Model.HighestScore</div>
                        <div class="stat-note">Your best score achieved so far.</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-title">Games Played</div>
                            <div class="stat-icon">🎮</div>
                        </div>
                        <div class="stat-value">@Model.GamesPlayed</div>
                        <div class="stat-note">Total completed game sessions.</div>
                    </div>

                    <div class="stat-card">
                        <div class="stat-top">
                            <div class="stat-title">Current Rank</div>
                            <div class="stat-icon">🥇</div>
                        </div>
                        <div class="stat-value">#@Model.CurrentRank</div>
                        <div class="stat-note">Based on your highest score.</div>
                    </div>
                </div>
            </div>

            <div class="card hero-card span-8 stagger-2">
                <div class="card-inner">
                    <div class="hero-content">
                        <div class="hero-text">
                            <div class="hero-mini">Player Dashboard</div>
                            <h2 class="hero-title">Ready for the next round?</h2>
                            <p class="hero-desc">
                                Start a new game, challenge yourself, and try to beat your highest score while improving your rank and activity history.
                            </p>

                            <div class="hero-actions">
                                <a asp-controller="Game" asp-action="Index" class="btn-main">
                                    <span>▶</span>
                                    <span>Play Game</span>
                                </a>

                                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="btn-soft">
                                    <span>👤</span>
                                    <span>My Profile</span>
                                </a>
                            </div>
                        </div>

                        <div class="hero-visual">
                            <div class="hero-visual-inner">🎯</div>
                        </div>
                    </div>
                </div>
            </div>

            <div class="card span-4 stagger-3">
                <div class="card-inner">
                    <div class="section-title">
                        <span class="icon">⚡</span>
                        Quick Links
                    </div>
                    <p class="section-subtext">Fast access to the most used dashboard actions.</p>

                    <div class="quick-actions">
                        <a asp-controller="Game" asp-action="Index" class="quick-card">
                            <div class="quick-icon">▶</div>
                            <div class="quick-title">Start Game</div>
                            <div class="quick-text">Begin a new game session now.</div>
                        </a>

                        <a asp-area="Identity" asp-page="/Account/Manage/Index" class="quick-card">
                            <div class="quick-icon">👤</div>
                            <div class="quick-title">My Profile</div>
                            <div class="quick-text">Manage your account and details.</div>
                        </a>

                        <a asp-controller="Home" asp-action="Privacy" class="quick-card">
                            <div class="quick-icon">📘</div>
                            <div class="quick-title">Game Rules</div>
                            <div class="quick-text">Read how the game works.</div>
                        </a>
                    </div>
                </div>
            </div>

            <div class="card span-12 stagger-4">
                <div class="card-inner">
                    <div class="section-title">
                        <span class="icon">🕘</span>
                        Recent Activity
                    </div>
                    <p class="section-subtext">Your latest completed game sessions.</p>

                    @if (Model.RecentGames != null && Model.RecentGames.Any())
                    {
                        <ul class="activity-list">
                            @foreach (var game in Model.RecentGames)
                            {
                                <li class="activity-item">
                                    <div class="activity-left">
                                        <div class="activity-icon">🎲</div>
                                        <div class="activity-details">
                                            <strong>@game.ResultText</strong>
                                            <span>@game.PlayedAt.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                                        </div>
                                    </div>

                                    <div class="score-badge">@game.Score pts</div>
                                </li>
                            }
                        </ul>
                    }
                    else
                    {
                        <div class="empty-state">
                            <span class="empty-emoji">🎮</span>
                            <strong>No games played yet</strong>
                            <p>Your recent game history will appear here after you play.</p>
                        </div>
                    }
                </div>
            </div>

        </div>
    </div>
</div>