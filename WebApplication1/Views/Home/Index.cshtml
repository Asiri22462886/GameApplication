@model WebApplication1.ViewModels.DashboardViewModel

@{
    ViewData["Title"] = "Game Dashboard";
}

<style>
    body {
        background: radial-gradient(circle at top left, rgba(59,130,246,.18), transparent 30%), radial-gradient(circle at bottom right, rgba(16,185,129,.18), transparent 30%), linear-gradient(135deg, #0f172a 0%, #111827 45%, #1e1b4b 100%);
        min-height: 100vh;
    }

    .dashboard-page {
        padding: 40px 0 60px;
        color: #fff;
    }

    .dashboard-shell {
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 16px;
    }

    .dashboard-hero {
        border-radius: 28px;
        padding: 36px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: 0 18px 60px rgba(0,0,0,.35);
        margin-bottom: 28px;
    }

    .dashboard-badge {
        display: inline-block;
        padding: 8px 14px;
        border-radius: 999px;
        background: rgba(59,130,246,.18);
        color: #bfdbfe;
        font-size: .85rem;
        font-weight: 700;
        letter-spacing: .08em;
        text-transform: uppercase;
        margin-bottom: 16px;
    }

    .dashboard-hero h1 {
        font-size: 2.8rem;
        font-weight: 800;
        margin-bottom: 10px;
    }

    .dashboard-hero p {
        font-size: 1.05rem;
        color: #d1d5db;
        max-width: 700px;
        margin-bottom: 0;
    }

    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(12, 1fr);
        gap: 22px;
    }

    .dashboard-card {
        border-radius: 24px;
        background: rgba(255,255,255,0.08);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(14px);
        -webkit-backdrop-filter: blur(14px);
        box-shadow: 0 18px 60px rgba(0,0,0,.25);
        padding: 24px;
        color: #fff;
    }

    .card-title {
        font-size: 1.1rem;
        font-weight: 800;
        margin-bottom: 16px;
    }

    .span-4 {
        grid-column: span 4;
    }

    .span-6 {
        grid-column: span 6;
    }

    .span-12 {
        grid-column: span 12;
    }

    .stat-value {
        font-size: 2rem;
        font-weight: 800;
        margin-bottom: 6px;
    }

    .stat-label {
        color: #cbd5e1;
        margin-bottom: 0;
    }

    .play-btn {
        display: inline-block;
        text-decoration: none;
        border: none;
        border-radius: 16px;
        padding: 14px 22px;
        font-size: 1rem;
        font-weight: 800;
        letter-spacing: .03em;
        background: linear-gradient(90deg, #2563eb, #7c3aed);
        color: #fff;
        box-shadow: 0 14px 30px rgba(37,99,235,.35);
        transition: transform .2s ease, box-shadow .2s ease;
    }

        .play-btn:hover {
            color: #fff;
            transform: translateY(-2px);
            box-shadow: 0 18px 34px rgba(124,58,237,.4);
        }

    .secondary-btn {
        display: inline-block;
        text-decoration: none;
        border-radius: 14px;
        padding: 12px 18px;
        font-weight: 700;
        color: #dbeafe;
        border: 1px solid rgba(255,255,255,.16);
        background: rgba(255,255,255,.06);
    }

        .secondary-btn:hover {
            color: #fff;
            background: rgba(255,255,255,.1);
        }

    .dashboard-actions {
        display: flex;
        gap: 12px;
        flex-wrap: wrap;
        margin-top: 20px;
    }

    .feature-list {
        display: grid;
        gap: 14px;
        margin: 0;
        padding: 0;
        list-style: none;
    }

        .feature-list li {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #e5e7eb;
            font-weight: 500;
        }

    .feature-icon {
        width: 38px;
        height: 38px;
        border-radius: 12px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.1);
        font-size: 1.1rem;
        flex-shrink: 0;
    }

    .activity-list {
        list-style: none;
        padding: 0;
        margin: 0;
        display: grid;
        gap: 12px;
    }

    .activity-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 12px;
        padding: 14px 16px;
        border-radius: 16px;
        background: rgba(255,255,255,.06);
        border: 1px solid rgba(255,255,255,.08);
    }

        .activity-item strong {
            display: block;
            margin-bottom: 3px;
        }

        .activity-item span {
            color: #cbd5e1;
            font-size: .92rem;
        }

    .score-badge {
        min-width: 70px;
        text-align: center;
        padding: 8px 12px;
        border-radius: 12px;
        background: rgba(37,99,235,.22);
        color: #dbeafe;
        font-weight: 800;
    }

    @@media (max-width: 991.98px) {
        .span-4, .span-6, .span-12 {
            grid-column: span 12;
        }

        .dashboard-hero h1 {
            font-size: 2.2rem;
        }
    }
</style>

<div class="dashboard-page">
    <div class="dashboard-shell">

        <div class="dashboard-hero">
            <div class="dashboard-badge">Game Dashboard</div>
            <h1>Welcome back, @Model.UserName!</h1>
            <p>
                Start a new game, track your score progress, and improve your rank.
            </p>

            <div class="dashboard-actions">
                <a asp-controller="Game" asp-action="Index" class="play-btn">Play Now</a>
                <a asp-area="Identity" asp-page="/Account/Manage/Index" class="secondary-btn">My Profile</a>
            </div>
        </div>

        <div class="dashboard-grid">
            <div class="dashboard-card span-4">
                <div class="card-title">Highest Score</div>
                <div class="stat-value">@Model.HighestScore</div>
                <p class="stat-label">Your best score so far</p>
            </div>

            <div class="dashboard-card span-4">
                <div class="card-title">Games Played</div>
                <div class="stat-value">@Model.GamesPlayed</div>
                <p class="stat-label">Total completed game sessions</p>
            </div>

            <div class="dashboard-card span-4">
                <div class="card-title">Current Rank</div>
                <div class="stat-value">@Model.CurrentRank</div>
                <p class="stat-label">Based on your highest score</p>
            </div>

            <div class="dashboard-card span-6">
                <div class="card-title">Quick Actions</div>
                <div class="dashboard-actions">
                    <a asp-controller="Game" asp-action="Index" class="play-btn">Start Game</a>
                    <a asp-controller="Home" asp-action="Privacy" class="secondary-btn">Game Rules</a>
                </div>
            </div>

            <div class="dashboard-card span-6">
                <div class="card-title">Game Features</div>
                <ul class="feature-list">
                    <li><span class="feature-icon">🎯</span><span>Score points for correct answers</span></li>
                    <li><span class="feature-icon">❤️</span><span>Three lives per game session</span></li>
                    <li><span class="feature-icon">🧠</span><span>Improve memory and word recognition</span></li>
                    <li><span class="feature-icon">🏆</span><span>Track your highest score history</span></li>
                </ul>
            </div>

            <div class="dashboard-card span-12">
                <div class="card-title">Recent Activity</div>

                @if (Model.RecentGames.Any())
                {
                    <ul class="activity-list">
                        @foreach (var game in Model.RecentGames)
                        {
                            <li class="activity-item">
                                <div>
                                    <strong>@game.ResultText</strong>
                                    <span>@game.PlayedAt.ToLocalTime().ToString("dd MMM yyyy hh:mm tt")</span>
                                </div>
                                <div class="score-badge">@game.Score</div>
                            </li>
                        }
                    </ul>
                }
                else
                {
                    <ul class="activity-list">
                        <li class="activity-item">
                            <div>
                                <strong>No games played yet</strong>
                                <span>Your latest game history will appear here</span>
                            </div>
                            <div class="score-badge">--</div>
                        </li>
                    </ul>
                }
            </div>
        </div>
    </div>
</div>