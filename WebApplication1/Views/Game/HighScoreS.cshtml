@model IEnumerable<WebApplication1.Models.LeaderBoardDto>

@{
    ViewData["Title"] = "Leaderboard";
    var rank = 1;
}

<div class="game-shell leaderboard-shell">
    <div class="game-bg"></div>

    <div class="container py-4 py-lg-5">
        <div class="leaderboard-wrap">
            <div class="leaderboard-head">
                <div>
                    <div class="eyebrow">Hall of Fame</div>
                    <h1 class="page-title">Leaderboard</h1>
                    <p class="page-subtitle">Top players and their highest scores.</p>
                </div>

                <div class="head-actions">
                    <a asp-controller="Game" asp-action="Index" class="neon-btn ghost-btn">Back to Game</a>
                    <a asp-controller="Game" asp-action="History" class="neon-btn primary-btn">My History</a>
                </div>
            </div>

            @if (Model == null || !Model.Any())
            {
                <div class="empty-state-panel trophy-empty">
                    <div class="empty-orb gold-orb"></div>
                    <div class="empty-icon">🏆</div>
                    <div class="empty-kicker">Leaderboard Empty</div>
                    <h3 class="empty-title">No high scores yet</h3>
                    <p class="empty-text">
                        The leaderboard is waiting for its first champion. Play now and set the first record.
                    </p>

                    <div class="empty-actions">
                        <a asp-controller="Game" asp-action="Index" class="neon-btn primary-btn">Start Game</a>
                        <a asp-controller="Game" asp-action="History" class="neon-btn ghost-btn">My History</a>
                    </div>
                </div>
            }
            else
            {
                <div class="leaderboard-card">
                    <div class="table-responsive">
                        <table class="leader-table">
                            <thead>
                                <tr>
                                    <th>Rank</th>
                                    <th>User</th>
                                    <th>High Score</th>
                                    <th>Updated</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var item in Model.OrderByDescending(x => x.HighestScore))
                                {
                                    var topClass = rank == 1 ? "gold" : rank == 2 ? "silver" : rank == 3 ? "bronze" : "";
                                    <tr class="@topClass">
                                        <td>
                                            <div class="rank-badge @topClass">#@rank</div>
                                        </td>
                                        <td class="user-cell">@item.UserName</td>
                                        <td>
                                            <span class="highscore-number">@item.HighestScore</span>
                                        </td>
                                        <td>@item.UpdatedAt.ToString("yyyy-MM-dd HH:mm")</td>
                                    </tr>
                                    rank++;
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@section Styles {
    <style>
        .leaderboard-shell {
            position: relative;
            min-height: 100vh;
            overflow: hidden;
            background: radial-gradient(circle at 20% 10%, rgba(255, 215, 0, .12), transparent 24%), radial-gradient(circle at 80% 10%, rgba(0, 212, 255, .12), transparent 28%), radial-gradient(circle at 50% 100%, rgba(124, 92, 255, .14), transparent 30%), linear-gradient(135deg, #09111f 0%, #0a1530 45%, #080d16 100%);
            color: #eef6ff;
        }

        .game-bg {
            position: absolute;
            inset: 0;
            pointer-events: none;
            opacity: .45;
            background-image: linear-gradient(rgba(255,255,255,.035) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.035) 1px, transparent 1px);
            background-size: 28px 28px;
        }

        .leaderboard-wrap {
            position: relative;
            z-index: 2;
        }

        .leaderboard-head {
            display: flex;
            justify-content: space-between;
            gap: 20px;
            align-items: center;
            margin-bottom: 24px;
            flex-wrap: wrap;
        }

        .eyebrow {
            display: inline-block;
            font-size: .8rem;
            letter-spacing: .22em;
            text-transform: uppercase;
            color: #ffe082;
            margin-bottom: 8px;
        }

        .page-title {
            margin: 0;
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 800;
            color: #fff;
        }

        .page-subtitle {
            margin: 10px 0 0;
            color: #a9bfd8;
        }

        .head-actions {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .neon-btn {
            display: inline-flex;
            align-items: center;
            justify-content: center;
            min-height: 46px;
            padding: 0 18px;
            border-radius: 14px;
            font-weight: 700;
            text-decoration: none;
            transition: .25s ease;
            border: 1px solid rgba(255,255,255,.14);
        }

        .primary-btn {
            background: linear-gradient(135deg, #ffb800, #ff7a00);
            color: #111;
            box-shadow: 0 10px 30px rgba(255, 184, 0, .18);
        }

        .ghost-btn {
            background: rgba(255,255,255,.06);
            color: #eef6ff;
            backdrop-filter: blur(12px);
        }

        .leaderboard-card,
        .empty-state-panel {
            border-radius: 28px;
            border: 1px solid rgba(255,255,255,.09);
            background: rgba(11, 18, 33, .7);
            backdrop-filter: blur(18px);
            box-shadow: 0 18px 55px rgba(0,0,0,.35);
        }

        .leaderboard-card {
            padding: 12px;
        }

        .empty-state-panel {
            text-align: center;
            padding: 56px 24px;
        }

        .leader-table {
            width: 100%;
            border-collapse: collapse;
            color: #eef6ff;
            min-width: 760px;
        }

            .leader-table thead th {
                padding: 16px 14px;
                border-bottom: 1px solid rgba(255,255,255,.08);
                text-transform: uppercase;
                font-size: .82rem;
                letter-spacing: .08em;
                color: #9edfff;
                background: rgba(255,255,255,.03);
            }

            .leader-table tbody td {
                padding: 18px 14px;
                border-bottom: 1px solid rgba(255,255,255,.06);
                vertical-align: middle;
            }

        .rank-badge {
            min-width: 70px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            padding: 8px 14px;
            border-radius: 999px;
            font-weight: 800;
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
        }

            .rank-badge.gold {
                background: rgba(255, 215, 0, .16);
                color: #ffd86a;
                border-color: rgba(255, 215, 0, .28);
            }

            .rank-badge.silver {
                background: rgba(192, 192, 192, .16);
                color: #e7edf5;
                border-color: rgba(192, 192, 192, .22);
            }

            .rank-badge.bronze {
                background: rgba(205, 127, 50, .18);
                color: #ffbd8c;
                border-color: rgba(205, 127, 50, .28);
            }

        .highscore-number {
            display: inline-block;
            min-width: 64px;
            text-align: center;
            font-size: 1.08rem;
            font-weight: 800;
            color: #7ef9ff;
            background: rgba(0, 212, 255, .10);
            border: 1px solid rgba(0, 212, 255, .24);
            border-radius: 999px;
            padding: 8px 14px;
        }

        .user-cell {
            font-weight: 700;
            color: #fff;
        }
    </style>
}