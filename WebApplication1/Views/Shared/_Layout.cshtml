<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Word Game</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)

    <style>
        html {
            font-size: 14px;
        }

        @@media (min-width: 768px) {
            html {
                font-size: 16px;
            }
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
            background: radial-gradient(circle at top left, rgba(59,130,246,.14), transparent 24%), radial-gradient(circle at bottom right, rgba(139,92,246,.14), transparent 24%), linear-gradient(135deg, #0f172a 0%, #111827 45%, #1e1b4b 100%);
            display: flex;
            flex-direction: column;
            overflow-x: hidden;
        }

        a {
            text-decoration: none;
        }

        .app-header {
            position: sticky;
            top: 0;
            z-index: 1050;
            padding: 14px 0;
            background: transparent;
        }

        .app-nav {
            max-width: 1320px;
            margin: 0 auto;
            padding: 0 14px;
        }

        .navbar-modern {
            border-radius: 24px;
            padding: 14px 18px;
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.12);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 16px 45px rgba(0,0,0,.25);
        }

        .brand-modern {
            display: flex;
            align-items: center;
            gap: 12px;
            color: #fff !important;
            font-weight: 800;
            font-size: 1.15rem;
            letter-spacing: .02em;
        }

        .brand-logo {
            width: 42px;
            height: 42px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            box-shadow: 0 10px 24px rgba(37,99,235,.28);
            font-size: 1.15rem;
            color: #fff;
            flex-shrink: 0;
        }

        .brand-text {
            display: flex;
            flex-direction: column;
            line-height: 1.05;
        }

        .brand-title {
            color: #fff;
            font-size: 1rem;
            font-weight: 800;
        }

        .brand-subtitle {
            color: #cbd5e1;
            font-size: .75rem;
            font-weight: 600;
        }

        .navbar-toggler {
            border: 1px solid rgba(255,255,255,.16);
            background: rgba(255,255,255,.08);
            border-radius: 14px;
            padding: 8px 10px;
        }

            .navbar-toggler:focus {
                box-shadow: none;
            }

        .navbar-toggler-icon {
            filter: invert(1);
        }

        .navbar-nav {
            gap: 8px;
        }

        .nav-link-modern {
            color: #e5e7eb !important;
            font-weight: 700;
            padding: 10px 16px !important;
            border-radius: 14px;
            transition: all .22s ease;
            display: inline-flex;
            align-items: center;
            gap: 8px;
        }

            .nav-link-modern:hover,
            .nav-link-modern.active {
                color: #fff !important;
                background: rgba(255,255,255,.10);
                transform: translateY(-1px);
            }

        .nav-icon {
            font-size: 1rem;
            line-height: 1;
        }

        .login-slot {
            display: flex;
            align-items: center;
            margin-left: 14px;
            padding-left: 14px;
            border-left: 1px solid rgba(255,255,255,.10);
        }

        .main-wrap {
            flex: 1;
            width: 100%;
            max-width: 1320px;
            margin: 0 auto;
            padding: 10px 14px 24px;
        }

        .page-shell {
            min-height: calc(100vh - 180px);
        }

        .footer-modern {
            margin-top: auto;
            padding: 18px 14px 26px;
        }

        .footer-box {
            max-width: 1320px;
            margin: 0 auto;
            padding: 18px 22px;
            border-radius: 20px;
            background: rgba(255,255,255,.06);
            border: 1px solid rgba(255,255,255,.10);
            backdrop-filter: blur(12px);
            -webkit-backdrop-filter: blur(12px);
            color: #cbd5e1;
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 12px;
            flex-wrap: wrap;
        }

            .footer-box a {
                color: #dbeafe;
                font-weight: 600;
            }

                .footer-box a:hover {
                    color: #fff;
                }

        @@media (max-width: 991.98px) {
            .navbar-nav {
                gap: 4px;
                margin-top: 12px;
            }

            .login-slot {
                margin-left: 0;
                padding-left: 0;
                border-left: none;
                margin-top: 12px;
                padding-top: 12px;
                border-top: 1px solid rgba(255,255,255,.10);
            }

            .navbar-modern {
                border-radius: 20px;
            }
        }

        @@media (max-width: 576px) {
            .brand-subtitle {
                display: none;
            }

            .main-wrap {
                padding-left: 10px;
                padding-right: 10px;
            }

            .footer-box {
                padding: 16px;
            }
        }
    </style>
</head>
<body>
    <header class="app-header">
        <div class="app-nav">
            <nav class="navbar navbar-expand-lg navbar-modern">
                <div class="container-fluid px-0">
                    <a class="navbar-brand brand-modern" asp-area="" asp-controller="Home" asp-action="Index">
                        <span class="brand-logo">🎮</span>
                        <span class="brand-text">
                            <span class="brand-title">Word Game</span>
                            <span class="brand-subtitle">Play • Score • Rank</span>
                        </span>
                    </a>

                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar"
                            aria-controls="mainNavbar" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="navbar-toggler-icon"></span>
                    </button>

                    <div class="collapse navbar-collapse" id="mainNavbar">
                        <ul class="navbar-nav mx-auto">
                            <li class="nav-item">
                                <a class="nav-link nav-link-modern" asp-area="" asp-controller="Home" asp-action="Index">
                                    <span class="nav-icon">🏠</span>
                                    <span>Home</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-link-modern" asp-area="" asp-controller="Game" asp-action="Index">
                                    <span class="nav-icon">▶</span>
                                    <span>Play Game</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-link-modern" asp-area="" asp-controller="Game" asp-action="HighScores">
                                    <span class="nav-icon">🏆</span>
                                    <span>Leaderboard</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-link-modern" asp-area="" asp-controller="Game" asp-action="History">
                                    <span class="nav-icon">🕘</span>
                                    <span>History</span>
                                </a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link nav-link-modern" asp-area="" asp-controller="Home" asp-action="Privacy">
                                    <span class="nav-icon">📘</span>
                                    <span>Game Rules</span>
                                </a>
                            </li>
                        </ul>

                        <div class="login-slot">
                            <partial name="_LoginPartial" />
                        </div>
                    </div>
                </div>
            </nav>
        </div>
    </header>

    <div class="main-wrap">
        <main role="main" class="page-shell">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-modern">
        <div class="footer-box">
            <div>&copy; 2026 - Word Game</div>
            <div>
                <a asp-area="" asp-controller="Home" asp-action="Privacy">Game Rules</a>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>