@page
@model LoginModel
@{
    ViewData["Title"] = "Log in";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Word Game</title>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/WebApplication1.styles.css" asp-append-version="true" />

    <style>
        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            color: #fff;
            background: radial-gradient(circle at top left, rgba(59,130,246,.14), transparent 24%), radial-gradient(circle at bottom right, rgba(139,92,246,.14), transparent 24%), linear-gradient(135deg, #0f172a 0%, #111827 45%, #1e1b4b 100%);
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 24px 16px;
        }

        .login-page {
            width: 100%;
            max-width: 1100px;
        }

        .login-shell {
            display: grid;
            grid-template-columns: 1.1fr .9fr;
            overflow: hidden;
            border-radius: 30px;
            background: rgba(255,255,255,0.07);
            border: 1px solid rgba(255,255,255,0.12);
            backdrop-filter: blur(16px);
            -webkit-backdrop-filter: blur(16px);
            box-shadow: 0 20px 60px rgba(0,0,0,.30);
            min-height: 650px;
        }

        .login-left {
            padding: 48px;
            background: radial-gradient(circle at top right, rgba(59,130,246,.18), transparent 28%), linear-gradient(135deg, rgba(37,99,235,.14), rgba(124,58,237,.16));
            display: flex;
            flex-direction: column;
            justify-content: center;
        }

        .brand-pill {
            display: inline-flex;
            align-items: center;
            gap: 10px;
            padding: 10px 16px;
            border-radius: 999px;
            background: rgba(255,255,255,.10);
            border: 1px solid rgba(255,255,255,.14);
            color: #dbeafe;
            font-weight: 800;
            letter-spacing: .06em;
            text-transform: uppercase;
            font-size: .82rem;
            margin-bottom: 22px;
            width: fit-content;
        }

        .brand-icon {
            width: 36px;
            height: 36px;
            border-radius: 12px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #2563eb, #7c3aed);
            color: #fff;
            font-size: 1rem;
        }

        .login-title {
            font-size: clamp(2rem, 5vw, 3.5rem);
            line-height: 1.05;
            font-weight: 900;
            margin: 0 0 16px;
        }

        .login-text {
            color: #dbeafe;
            font-size: 1.02rem;
            line-height: 1.8;
            max-width: 520px;
            margin-bottom: 28px;
        }

        .feature-list {
            list-style: none;
            margin: 0;
            padding: 0;
            display: grid;
            gap: 14px;
            max-width: 480px;
        }

            .feature-list li {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 14px 16px;
                border-radius: 18px;
                background: rgba(255,255,255,.06);
                border: 1px solid rgba(255,255,255,.09);
                color: #e5e7eb;
                font-weight: 600;
            }

        .feature-icon {
            width: 40px;
            height: 40px;
            border-radius: 14px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
            background: rgba(255,255,255,.10);
            flex-shrink: 0;
        }

        .login-right {
            padding: 48px 40px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .login-card {
            width: 100%;
            max-width: 420px;
        }

        .form-title {
            font-size: 2rem;
            font-weight: 900;
            margin-bottom: 10px;
        }

        .form-subtitle {
            color: #cbd5e1;
            margin-bottom: 26px;
            line-height: 1.7;
        }

        .form-floating > .form-control,
        .form-floating > .form-control-plaintext {
            height: 60px;
            min-height: 60px;
            border-radius: 16px;
        }

        .form-control {
            background: rgba(255,255,255,.08);
            border: 1px solid rgba(255,255,255,.12);
            color: #fff;
        }

            .form-control:focus {
                background: rgba(255,255,255,.10);
                border-color: rgba(96,165,250,.7);
                box-shadow: 0 0 0 .2rem rgba(59,130,246,.18);
                color: #fff;
            }

        .form-floating > label {
            color: #cbd5e1;
        }

        .form-check-label,
        .forgot-link,
        .register-link,
        .resend-link {
            color: #dbeafe;
        }

            .forgot-link:hover,
            .register-link:hover,
            .resend-link:hover {
                color: #fff;
            }

        .login-btn {
            width: 100%;
            border: none;
            border-radius: 16px;
            padding: 15px 20px;
            font-size: 1rem;
            font-weight: 800;
            color: #fff;
            background: linear-gradient(90deg, #2563eb, #7c3aed);
            box-shadow: 0 14px 30px rgba(37,99,235,.28);
            transition: all .25s ease;
        }

            .login-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 18px 36px rgba(124,58,237,.34);
            }

        .bottom-links {
            margin-top: 22px;
            display: grid;
            gap: 10px;
        }

        .text-danger,
        .validation-summary-errors {
            color: #fecaca !important;
        }

        @@media (max-width: 991.98px) {
            .login-shell {
                grid-template-columns: 1fr;
            }

            .login-left {
                padding: 32px 24px;
            }

            .login-right {
                padding: 32px 24px 36px;
            }
        }

        @@media (max-width: 576px) {
            .login-title {
                font-size: 2rem;
            }

            .form-title {
                font-size: 1.7rem;
            }

            .login-left,
            .login-right {
                padding: 24px 18px;
            }
        }
    </style>
</head>
<body>
    <div class="login-page">
        <div class="login-shell">
            <div class="login-left">
                <div class="brand-pill">
                    <span class="brand-icon">🎮</span>
                    <span>Word Game</span>
                </div>

                <h1 class="login-title">Welcome Back</h1>
                <p class="login-text">
                    Sign in to continue your progress, check your score history, and climb the leaderboard.
                </p>

                <ul class="feature-list">
                    <li>
                        <span class="feature-icon">🏆</span>
                        <span>Track your highest score</span>
                    </li>
                    <li>
                        <span class="feature-icon">🕘</span>
                        <span>View your game history</span>
                    </li>
                    <li>
                        <span class="feature-icon">🎯</span>
                        <span>Play and improve your rank</span>
                    </li>
                </ul>
            </div>

            <div class="login-right">
                <div class="login-card">
                    <h2 class="form-title">Log in</h2>
                    <p class="form-subtitle">Enter your account details to access the game.</p>

                    <form id="account" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3" role="alert"></div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" autocomplete="username" aria-required="true" placeholder="name@example.com" />
                            <label asp-for="Input.Email">Email</label>
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="password" />
                            <label asp-for="Input.Password">Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger"></span>
                        </div>

                        <div class="form-check mb-3">
                            <label asp-for="Input.RememberMe" class="form-check-label">
                                <input class="form-check-input" asp-for="Input.RememberMe" />
                                @Html.DisplayNameFor(m => m.Input.RememberMe)
                            </label>
                        </div>

                        <button id="login-submit" type="submit" class="login-btn">Log in</button>

                        <div class="bottom-links">
                            <a class="forgot-link" id="forgot-password" asp-page="./ForgotPassword">Forgot your password?</a>
                            <a class="register-link" asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl">Create a new account</a>
                            <a class="resend-link" id="resend-confirmation" asp-page="./ResendEmailConfirmation">Resend email confirmation</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <partial name="_ValidationScriptsPartial" />
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>