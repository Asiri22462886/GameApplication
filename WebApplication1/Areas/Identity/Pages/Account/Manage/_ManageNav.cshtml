@inject SignInManager<IdentityUser> SignInManager
@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<style>
    .manage-nav-wrap {
        border-radius: 26px;
        background: rgba(255,255,255,0.07);
        border: 1px solid rgba(255,255,255,0.12);
        backdrop-filter: blur(16px);
        -webkit-backdrop-filter: blur(16px);
        box-shadow: 0 18px 50px rgba(0,0,0,.22);
        padding: 18px;
    }

    .manage-nav-title {
        display: flex;
        align-items: center;
        gap: 10px;
        margin-bottom: 16px;
        font-size: 1.05rem;
        font-weight: 800;
        color: #fff;
    }

    .manage-nav-title-icon {
        width: 40px;
        height: 40px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(135deg, #2563eb, #7c3aed);
        color: #fff;
        box-shadow: 0 10px 24px rgba(37,99,235,.24);
        flex-shrink: 0;
    }

    .manage-nav-list {
        display: grid;
        gap: 10px;
    }

    .manage-nav-link {
        display: flex !important;
        align-items: center;
        gap: 12px;
        padding: 14px 16px !important;
        border-radius: 18px !important;
        background: rgba(255,255,255,.04);
        border: 1px solid rgba(255,255,255,.08);
        color: #dbeafe !important;
        font-weight: 700;
        text-decoration: none;
        transition: all .22s ease;
    }

        .manage-nav-link:hover {
            color: #fff !important;
            background: rgba(255,255,255,.08);
            border-color: rgba(255,255,255,.14);
            transform: translateX(4px);
        }

        .manage-nav-link.active {
            color: #fff !important;
            background: linear-gradient(135deg, rgba(37,99,235,.26), rgba(124,58,237,.24));
            border-color: rgba(147,197,253,.28);
            box-shadow: 0 12px 28px rgba(37,99,235,.14);
        }

    .manage-nav-icon {
        width: 38px;
        height: 38px;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        background: rgba(255,255,255,.08);
        color: #fff;
        flex-shrink: 0;
        font-size: 1rem;
    }

    .manage-nav-link.active .manage-nav-icon {
        background: rgba(255,255,255,.14);
    }

    .manage-nav-text {
        line-height: 1.2;
    }

        .manage-nav-text strong {
            display: block;
            font-size: .98rem;
            font-weight: 800;
            margin-bottom: 2px;
        }

        .manage-nav-text span {
            display: block;
            color: #cbd5e1;
            font-size: .82rem;
            font-weight: 500;
        }

    @@media (max-width: 991.98px) {
        .manage-nav-wrap {
            padding: 14px;
        }

        .manage-nav-link {
            padding: 12px 14px !important;
        }
    }
</style>

<div class="manage-nav-wrap">
    <div class="manage-nav-title">
        <span class="manage-nav-title-icon">👤</span>
        <span>Account Settings</span>
    </div>

    <ul class="nav flex-column manage-nav-list">
        <li class="nav-item">
            <a class="nav-link manage-nav-link @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
                <span class="manage-nav-icon">🪪</span>
                <span class="manage-nav-text">
                    <strong>Profile</strong>
                    <span>View and update your account profile</span>
                </span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link manage-nav-link @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
                <span class="manage-nav-icon">✉️</span>
                <span class="manage-nav-text">
                    <strong>Email</strong>
                    <span>Manage your email address</span>
                </span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link manage-nav-link @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
                <span class="manage-nav-icon">🔒</span>
                <span class="manage-nav-text">
                    <strong>Password</strong>
                    <span>Change and secure your password</span>
                </span>
            </a>
        </li>

        @if (hasExternalLogins)
        {
            <li id="external-logins" class="nav-item">
                <a id="external-login" class="nav-link manage-nav-link @ManageNavPages.ExternalLoginsNavClass(ViewContext)" asp-page="./ExternalLogins">
                    <span class="manage-nav-icon">🌐</span>
                    <span class="manage-nav-text">
                        <strong>External Logins</strong>
                        <span>Manage connected sign-in providers</span>
                    </span>
                </a>
            </li>
        }

        <li class="nav-item">
            <a class="nav-link manage-nav-link @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
                <span class="manage-nav-icon">🛡️</span>
                <span class="manage-nav-text">
                    <strong>Two-Factor Authentication</strong>
                    <span>Add extra protection to your account</span>
                </span>
            </a>
        </li>

        <li class="nav-item">
            <a class="nav-link manage-nav-link @ManageNavPages.PersonalDataNavClass(ViewContext)" id="personal-data" asp-page="./PersonalData">
                <span class="manage-nav-icon">📁</span>
                <span class="manage-nav-text">
                    <strong>Personal Data</strong>
                    <span>Download or remove your account data</span>
                </span>
            </a>
        </li>
    </ul>
</div>